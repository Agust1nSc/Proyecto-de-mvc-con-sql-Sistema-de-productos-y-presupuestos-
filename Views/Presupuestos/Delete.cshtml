@model Presupuesto

<h2>Eliminar Presupuesto</h2>

<p>¿Seguro que deseas eliminar el presupuesto de <strong>@Model.NombreDestinatario</strong>?</p>

<form method="post" asp-action="Delete">
    <input type="hidden" asp-for="IdPresupuesto" />

    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a class="btn btn-secondary" href="/Presupuestos">Cancelar</a>
</form>
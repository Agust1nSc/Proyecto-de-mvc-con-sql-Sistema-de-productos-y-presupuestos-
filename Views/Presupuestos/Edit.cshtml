@model MVC.ViewModels.PresupuestoViewModel

<h2>Editar Presupuesto</h2>

<form method="post" asp-action="Edit">
    <input type="hidden" asp-for="IdPresupuesto" />

    <div class="form-group">
        <label>Nombre Destinatario</label>
        <input class="form-control" asp-for="NombreDestinatario" required />
        <span asp-validation-for="NombreDestinatario" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Fecha</label>
        <input class="form-control" asp-for="FechaCreacion" type="date" required />
        <span asp-validation-for="FechaCreacion" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    <a class="btn btn-secondary" href="/Presupuestos">Volver</a>
</form>

@section Scripts {
 <partial name="_ValidationScriptsPartial" />
}